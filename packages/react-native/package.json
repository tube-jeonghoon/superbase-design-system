{
  "name": "@superbase/react-native",
  "version": "0.3.0",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tube-jeonghoon/superbase-design-system.git",
    "directory": "packages/react-native"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-native": ">=0.74",
    "react-native-svg": ">=15"
  },
  "dependencies": {
    "@superbase/icons": "workspace:*",
    "@superbase/tokens": "workspace:*"
  },
  "devDependencies": {
    "@superbase/icons": "workspace:*",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.1.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "jsdom": "^25.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-native": "^0.86.0",
    "react-native-svg": "^15.0.0",
    "react-native-web": "^0.19.13",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
